# ═══════════════════════════════════════════════════════════════
# Serenia — Configuration bootstrap
# ═══════════════════════════════════════════════════════════════
# Toute la configuration métier (identifiants OVH, passphrase,
# sources, planification) se fait via la webUI après le premier
# démarrage : http://<ip-du-nas>:<SERENIA_PORT>
# ═══════════════════════════════════════════════════════════════

# Port d'exposition de la webUI (défaut : 8765)
SERENIA_PORT=8765

# ─── Authentification ─────────────────────────────────────────
# Fortement recommandé. Si laissé vide, l'accès est libre (LAN uniquement).
SERENIA_USER=admin
SERENIA_PASSWORD=changez-moi

# ─── Fuseau horaire ───────────────────────────────────────────
TZ=Europe/Paris
